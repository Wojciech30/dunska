{
  "meta": {
    "project": "Dunska Admin Panel",
    "version": "1.0.0",
    "direction": "refresh-premium-minimal"
  },
  "color": {
    "bg/canvas": "#F6F5F2",
    "bg/surface": "#FFFFFF",
    "bg/surface-muted": "#F1EFEA",
    "bg/sidebar": "#171717",
    "text/primary": "#1C1B19",
    "text/secondary": "#6C665E",
    "text/inverse": "#FFFFFF",
    "text/subtle": "#A79F96",
    "border/default": "#E8E3DB",
    "border/strong": "#DAD3C8",
    "accent/brand": "#B3976C",
    "accent/brand-hover": "#9A815A",
    "status/danger": "#B13A2B",
    "status/success": "#2F8C52",
    "overlay/modal": "#0A0A0AA6"
  },
  "space": {
    "2": 2,
    "4": 4,
    "8": 8,
    "12": 12,
    "16": 16,
    "20": 20,
    "24": 24,
    "32": 32,
    "40": 40,
    "48": 48,
    "64": 64
  },
  "radius": {
    "sm": 6,
    "md": 10,
    "lg": 14,
    "pill": 999
